WORLDCLASS_EMAIL=tu_email@ejemplo.com
WORLDCLASS_PASSWORD=tu_password
DISCOVERY_EMAIL=tu_email@ejemplo.com
DISCOVERY_PASSWORD=tu_password
WORLDCLASS_BASE_URL=https://worldclass.systemsoca.com
DISCOVERY_BASE_URL=https://discovery.systemsoca.com
LOGIN_PATH=/login
CONTRATOS_PATH=/contratos
WORLDCLASS_SEDE=WCG - GUAYAQUIL
WORLDCLASS_FECHA_INICIAL=2023-01-01
WORLDCLASS_FECHA_FINAL=2026-05-16
DISCOVERY_FECHA_INICIAL=2025-01-01
DISCOVERY_FECHA_FINAL=2026-05-07
ESTADOS_DEFAULT=PROCE,CERO,GASTO LEGAL,SEPARACION,PEDDING
PAGE_NAVIGATION_TIMEOUT=40000
PAGE_ACTION_TIMEOUT=20000
PAGE_READY_STATE_TIMEOUT=15000
CONCURRENCY=4
TIMING_FACTOR=1.0
LOG_LEVEL=INFO
EXPORT_CSV=true
EXPORT_XLSX=false
AUTO_REDUCE_ON_ERRORS=true
ERROR_THRESHOLD=10
MIN_CONCURRENCY=1
CONCURRENCY_REDUCTION_STEP=1
AUTO_RECOVERY=true
STABLE_THRESHOLD=20
RECOVERY_STEP=1
MAX_CONCURRENCY=8
SELECTOR_EMAIL=input[type="email"], input#email
SELECTOR_PASSWORD=input[type="password"], input#password
SELECTOR_SUBMIT=button[type="submit"], input[type="submit"]
SELECTOR_SEDE=select#bus_sede
SELECTOR_FECHA_INICIAL=input#bus_f1
SELECTOR_FECHA_FINAL=input#bus_f2
SELECTOR_ESTADO=select#bus_estado
SELECTOR_BUSCAR=button[onclick*="buscarXcs"]
SELECTOR_CONTRATO_LINK=a[href*="/vercontrato/"]
